# DhanHQ API Configuration
# Copy this file to .env and fill in your actual credentials

# Your DhanHQ Client ID (required)
DHAN_CLIENT_ID=your_client_id_here

# Your DhanHQ Access Token (required)
DHAN_ACCESS_TOKEN=your_access_token_here

# DhanHQ API Base URL (optional, defaults to production)
DHAN_API_BASE_URL=https://api.dhan.co/v2

# MCP Server Configuration
MCP_SERVER_PORT=8000
MCP_SERVER_HOST=localhost

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=dhan_mcp.log

# Development/Demo Mode (set to true for testing without real API calls)
DEMO_MODE=false

# Security Settings
ENABLE_AUTH=false
API_KEY=your_api_key_for_mcp_access